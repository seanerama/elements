---
interface Props {
  prev: { symbol: string; name: string } | null;
  next: { symbol: string; name: string } | null;
}

const { prev, next } = Astro.props;
---

<nav class="prevnext" aria-label="Previous / next element">
  {
    prev ? (
      <a class="link" href={`/elements/${prev.symbol.toLowerCase()}`} rel="prev">
        <span class="dir" aria-hidden="true">
          ←
        </span>
        <span class="meta">
          <span class="kind">Prev</span>
          <span class="name">
            {prev.name} ({prev.symbol})
          </span>
        </span>
      </a>
    ) : (
      <span class="link link--disabled" aria-hidden="true">
        <span class="dir">←</span>
        <span class="meta">
          <span class="kind">Prev</span>
          <span class="name">—</span>
        </span>
      </span>
    )
  }

  <a class="home" href="/">Periodic Table</a>

  {
    next ? (
      <a class="link link--right" href={`/elements/${next.symbol.toLowerCase()}`} rel="next">
        <span class="meta meta--right">
          <span class="kind">Next</span>
          <span class="name">
            {next.name} ({next.symbol})
          </span>
        </span>
        <span class="dir" aria-hidden="true">
          →
        </span>
      </a>
    ) : (
      <span class="link link--right link--disabled" aria-hidden="true">
        <span class="meta meta--right">
          <span class="kind">Next</span>
          <span class="name">—</span>
        </span>
        <span class="dir">→</span>
      </span>
    )
  }
</nav>

<style>
  .prevnext {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-2xl);
    padding: var(--space-lg) 0;
    border-top: var(--border-rule);
  }

  .link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-md);
    text-decoration: none;
    color: var(--color-ink);
    padding: var(--space-xs) var(--space-md);
    border: var(--border-rule);
    background: var(--color-paper);
    transition: border-color var(--duration-base) var(--easing-out);
  }

  .link:hover {
    border: var(--border-rule-thick);
  }

  .link--disabled {
    opacity: 0.4;
    cursor: default;
  }

  .link--disabled:hover {
    border: var(--border-rule);
  }

  .link--right {
    justify-self: end;
  }

  .dir {
    font-family: var(--font-mono);
    font-size: var(--text-h3);
    color: var(--color-accent-vermillion);
    line-height: 1;
  }

  .meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: left;
  }

  .meta--right {
    text-align: right;
  }

  .kind {
    font-family: var(--font-sans);
    font-size: var(--text-eyebrow);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-ink-muted);
  }

  .name {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-weight: 500;
  }

  .home {
    font-family: var(--font-sans);
    font-size: var(--text-body-sm);
    color: var(--color-ink-muted);
    text-decoration: none;
    border-bottom: 1px dotted var(--color-rule);
    padding-bottom: 2px;
  }

  .home:hover {
    color: var(--color-accent-vermillion);
    border-bottom-color: var(--color-accent-vermillion);
  }
</style>
