---
import { electronShellGeometry } from '@/lib/bohr';

interface Props {
  protons: number;
  neutrons: number | null; // shown only if known
  electronsPerShell: readonly number[];
  size?: number;
}

const { protons, neutrons, electronsPerShell, size = 320 } = Astro.props;
const cx = size / 2;
const cy = size / 2;
const nucleusRadius = 22;
const shells = electronShellGeometry(electronsPerShell, size);
const nucleusLabel = neutrons === null ? `${protons}p` : `${protons}p · ${neutrons}n`;
---

<svg
  class="bohr"
  xmlns="http://www.w3.org/2000/svg"
  viewBox={`0 0 ${size} ${size}`}
  width={size}
  height={size}
  role="img"
  aria-label={`Electron shell diagram with ${shells.length} shells`}
>
  {/* shell rings */}
  {
    shells.map((s) => (
      <circle
        cx={cx}
        cy={cy}
        r={s.radius}
        fill="none"
        stroke="var(--color-rule)"
        stroke-width="0.75"
        stroke-dasharray="2 4"
      />
    ))
  }

  {/* nucleus */}
  <circle cx={cx} cy={cy} r={nucleusRadius} fill="var(--color-ink)"></circle>
  <text
    x={cx}
    y={cy}
    text-anchor="middle"
    dominant-baseline="central"
    fill="var(--color-paper)"
    font-family="var(--font-mono)"
    font-size="9"
    font-weight="500">{nucleusLabel}</text
  >

  {/* electrons */}
  {
    shells.map((s) =>
      s.electrons.map((e) => (
        <circle cx={e.x} cy={e.y} r="4.5" fill="var(--color-accent-prussian)" />
      )),
    )
  }

  {/* shell labels (bottom of each shell) */}
  {
    shells.map((s) => (
      <text
        x={cx}
        y={cy + s.radius + 10}
        text-anchor="middle"
        fill="var(--color-ink-muted)"
        font-family="var(--font-mono)"
        font-size="9"
      >
        {s.label}
      </text>
    ))
  }
</svg>

<style>
  .bohr {
    display: block;
    margin: 0 auto;
    max-width: 100%;
    height: auto;
  }
</style>
